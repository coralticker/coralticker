# CoralTicker — local environment template.
#
# Copy this file to `.env` (gitignored) at repo root and fill in real values
# from the Neon dashboard. Loaded by the Next.js dev/build server (via Next's
# built-in .env support) and by `scrapers/common/db.py` via python-dotenv.
#
# CI does NOT use this file — GitHub Actions injects the same variables via
# the workflow YAML `env:` block from repo secrets. `.env` exists only on
# developer laptops.
#
# Keep `.env` off shared drives, screenshots, and external chats. Never commit.
#
# Scope split (post-CTK-043 / CTK-036 cutovers — see CTK-015 plan §Tasks):
#   - Vercel-scope (Production / Preview / Development): NEON_DATABASE_URL +
#     DISCORD_*_INVITE_URL pair
#   - GH Actions-scope only (no frontend read path):     R2_* + SLACK_WEBHOOK_URL
#   - Local-only:                                        all of the above
# Add a row here whenever a new Vercel-scope key is introduced, per the
# baseline-declaration discipline named at CTK-015 plan §Risks L75.

# ---------------------------------------------------------------------------
# Vercel-scope: required in Production + Preview + Development.
# ---------------------------------------------------------------------------

# Neon Postgres connection string (post-CTK-043 cutover; see decision register
# row #65 in architecture-v1.md). Used by lib/db/neon.ts for the frontend
# (@neondatabase/serverless tagged-template client) and by scrapers/common/db.py
# (psycopg) for the backend. Format: postgresql://<user>:<pwd>@<host>/<db>?sslmode=require
NEON_DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require

# Discord invites — per-surface vars for join attribution via Discord's
# native invite tracking (CTK-126 D-5; keep-separate convention — do NOT
# consolidate or cross-wire the two). Permanent invites (expiry Never). Read
# at module scope with throw-on-missing (lib/db/neon.ts idiom) by
# app/corals/page.tsx (drops) and app/about/_components/social-links.tsx
# (about); needed at BUILD time — the pages inline the value at prerender,
# so rotating an invite requires a redeploy.
DISCORD_DROPS_INVITE_URL=https://discord.gg/<permanent-invite-code>
DISCORD_ABOUT_INVITE_URL=https://discord.gg/<permanent-invite-code>

# ---------------------------------------------------------------------------
# GH Actions-scope only: no frontend read path. Do NOT add these to Vercel.
# CI workflows inject via the workflow YAML `env:` block from repo secrets.
# ---------------------------------------------------------------------------

# Cloudflare R2 image storage per CTK-036 cut-2 (S3-compatible). Endpoint is
# derived as https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com; region must
# be "auto" in boto3 config (R2 is regionless). Token scope: Account token,
# Object Read & Write, restricted to the bucket named in R2_BUCKET_NAME.
# Public reads serve through the custom domain images.coralticker.com bound
# at the bucket's R2 Settings → Custom Domains; the access key here covers
# writes only.
R2_ACCOUNT_ID=<cloudflare-account-id>
R2_ACCESS_KEY_ID=<r2-token-access-key>
R2_SECRET_ACCESS_KEY=<r2-token-secret-key>
R2_BUCKET_NAME=coralticker-images

# Slack incoming webhook to the private operator channel (#coralticker-ops).
# Used by scraper-failure + daily-digest workflows per arch-v1.md §6.5.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<...>
