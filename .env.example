# CoralTicker scraper — local environment template.
#
# Copy this file to `.env` (gitignored) at repo root and fill in real values
# from the Supabase dashboard. Loaded by `scrapers/common/db.py` via
# python-dotenv at module import; consumed by `db.get_client()`.
#
# CI does NOT use this file — GitHub Actions injects the same variables via
# the workflow YAML `env:` block from repo secrets. `.env` exists only on
# developer laptops.
#
# Service role key bypasses Row Level Security per arch §1.3. Keep `.env`
# off shared drives, screenshots, and external chats. Never commit.

SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_KEY=<your-sb_secret-value>
